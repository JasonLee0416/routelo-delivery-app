{
  "name": "routelo",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "base64-js": "^1.5.1",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-file-system": "~56.0.0",
    "expo-font": "~56.0.7",
    "expo-image-manipulator": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "jpeg-js": "^0.4.4",
    "onnxruntime-react-native": "^1.24.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "onnxruntime-node": "^1.27.0",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "verify:ocr-models": "node scripts/verify-ocr-models.mjs",
    "verify:no-mlkit": "node scripts/verify-no-mlkit.mjs",
    "typecheck": "tsc --noEmit",
    "doctor": "npx --yes expo-doctor",
    "build:web": "expo export --platform web",
    "validate": "npm run verify:no-mlkit && npm run verify:ocr-models && npm run test:ci && npm run typecheck && npm run doctor && npm run build:web",
    "postinstall": "patch-package"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ]
  },
  "private": true
}
