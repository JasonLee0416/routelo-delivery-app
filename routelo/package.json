{
  "name": "routelo",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-file-system": "~56.0.0",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "doctor": "npx --yes expo-doctor",
    "build:web": "expo export --platform web",
    "validate": "npm run test:ci && npm run typecheck && npm run doctor && npm run build:web"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ]
  },
  "private": true
}
